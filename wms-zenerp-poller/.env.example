# ------------------------------------------------------------
# Conexão com o banco PostgreSQL do WMS
# ------------------------------------------------------------
DATABASE_URL=postgresql://usuario:senha@localhost:5432/wms

# ------------------------------------------------------------
# ZenERP - login automático (mesmo padrão do Boxer Requisições)
# ------------------------------------------------------------
# Onde o login acontece (POST /auth/login)
ZENERP_AUTH_BASE_URL=https://api.zenerp.app.br

# Onde os pedidos são consultados (pode ser diferente do login)
ZENERP_BASE_URL=https://boxer.zenerp.app.br

ZENERP_TENANT=boxer
ZENERP_USERNAME=compras@boxersoldas.com.br
ZENERP_PASSWORD=coloque_a_senha_aqui

# ------------------------------------------------------------
# Intervalo de consulta (em minutos) - decidimos 2 a 5 minutos
# ------------------------------------------------------------
POLL_INTERVAL_MINUTES=3
