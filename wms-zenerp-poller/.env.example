# ------------------------------------------------------------
# Conexão com o banco PostgreSQL do WMS
# ------------------------------------------------------------
DATABASE_URL=postgresql://usuario:senha@localhost:5432/wms

# ------------------------------------------------------------
# ZenERP
# ------------------------------------------------------------
# Mesma base do endpoint de estoque que você já usa
ZENERP_BASE_URL=https://api.zenerp.app.br/platform/openapi

# Ajuste este caminho assim que confirmar com o fornecedor do
# ZenERP qual é o endpoint correto de pedidos/ordens de separação.
# Por enquanto segue o mesmo padrão do endpoint de estoque conhecido.
ZENERP_PEDIDOS_PATH=/pedidos

ZENERP_BEARER_TOKEN=coloque_o_token_aqui
ZENERP_TENANT_KEY=coloque_a_tenant_key_aqui

# ------------------------------------------------------------
# Intervalo de consulta (em minutos) - decidimos 2 a 5 minutos
# ------------------------------------------------------------
POLL_INTERVAL_MINUTES=3
